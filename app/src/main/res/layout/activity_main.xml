<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/app_background"
    android:orientation="vertical"
    android:padding="24dp">

    <TextView
        android:id="@+id/titleText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/random_note_title"
        android:textColor="@color/on_vibrant"
        android:textSize="30sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/vaultStatusText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:text="@string/vault_not_selected"
        android:textColor="@color/on_vibrant_muted"
        android:textSize="14sp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:orientation="horizontal">

        <Button
            android:id="@+id/selectVaultButton"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:background="@drawable/button_secondary"
            android:textColor="@color/on_vibrant"
            android:layout_weight="1"
            android:text="@string/select_vault" />

        <Button
            android:id="@+id/randomNoteButton"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_marginStart="12dp"
            android:background="@drawable/button_primary"
            android:textColor="@color/on_vibrant"
            android:layout_weight="1"
            android:text="@string/show_random_note" />
    </LinearLayout>

    <ProgressBar
        android:id="@+id/loadingIndicator"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="16dp"
        android:indeterminateTint="@color/on_vibrant"
        android:visibility="gone" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="8dp"
        android:layout_weight="1"
        android:background="@drawable/note_panel"
        android:orientation="vertical">

        <TextView
            android:id="@+id/noteTitleText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/no_note_loaded"
            android:textColor="@color/on_surface"
            android:textSize="20sp"
            android:textStyle="bold" />

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginTop="12dp"
            android:layout_weight="1"
            android:fillViewport="true">

            <TextView
                android:id="@+id/noteContentText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:lineSpacingExtra="4dp"
                android:text="@string/random_note_empty_state"
                android:textColor="@color/on_surface"
                android:textIsSelectable="true"
                android:textSize="16sp" />
        </ScrollView>
    </LinearLayout>
</LinearLayout>
